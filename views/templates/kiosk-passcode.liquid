<!doctype html>
<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Kiosk — {{ listName | escape }}</title>
<style>body{margin:0;background:#f3f4f6;font-family:system-ui,sans-serif;font-size:16px;color:#111827}.card{max-width:22rem;margin:4rem auto;background:#fff;padding:2rem;border-radius:1rem;box-shadow:0 1px 3px #0002;text-align:center}h1{margin-top:0;font-size:1.25rem}.muted{color:#6b7280}input{box-sizing:border-box;width:100%;padding:.9rem;border:1px solid #d1d5db;border-radius:.5rem;font:inherit;font-size:1.25rem;text-align:center;letter-spacing:.2em;margin:1rem 0}button{border:0;border-radius:.5rem;padding:.9rem 1.4rem;font:inherit;font-size:1.1rem;font-weight:700;cursor:pointer;background:#4f46e5;color:#fff;width:100%}.error{background:#fee2e2;color:#b91c1c;padding:.6rem 1rem;border-radius:.5rem;margin-bottom:1rem;font-size:.9rem}</style></head>
<body><main class="card">
  <h1>{{ listName | escape }}</h1>
  <p class="muted">Enter the kiosk passcode to unlock check-in.</p>
  {% if error != blank %}<p class="error">{{ error | escape }}</p>{% endif %}
  <form method="post">
    <input type="password" inputmode="numeric" name="passcode" autofocus autocomplete="off" placeholder="Passcode">
    <button type="submit">Unlock</button>
  </form>
</main></body></html>

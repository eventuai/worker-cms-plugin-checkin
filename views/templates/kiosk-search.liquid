<!doctype html>
<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Search — {{ listName | escape }}</title>
<style>body{margin:0;background:#f3f4f6;font-family:system-ui,sans-serif;font-size:16px;color:#111827}.top{display:flex;justify-content:space-between;align-items:center;padding:1rem}.top a{color:#6b7280;text-decoration:none;font-size:.85rem}.card{max-width:28rem;margin:0 auto;padding:0 1rem 2rem}input{box-sizing:border-box;width:100%;padding:.8rem;border:1px solid #d1d5db;border-radius:.5rem;font:inherit;font-size:1rem}.result{display:block;background:#fff;border:1px solid #e5e7eb;border-radius:.5rem;padding:.9rem 1rem;margin-top:.75rem;text-decoration:none;color:#111827}.result b{display:block}.result span{color:#6b7280;font-size:.85rem}.badge{display:inline-block;padding:.1rem .5rem;border-radius:9999px;font-size:.7rem;font-weight:700;background:#dcfce7;color:#166534;margin-left:.5rem}.empty{color:#9ca3af;text-align:center;margin-top:2rem}</style></head>
<body>
<div class="top"><a href="/kiosk/{{ listId }}/scan">&larr; Scan</a><span>{{ listName | escape }}</span></div>
<main class="card">
  <form method="get">
    <input type="text" name="q" value="{{ query | escape }}" autofocus autocomplete="off" placeholder="Search name, email or company">
  </form>
  {% for guest in guests %}
    <a class="result" href="/kiosk/{{ listId }}/guests/{{ guest.id }}"><b>{{ guest.name | escape }}{% if guest.checkedIn %}<span class="badge">Checked in</span>{% endif %}</b><span>{{ guest.organization | escape }}</span></a>
  {% else %}
    <p class="empty">{% if query != blank %}No guests match "{{ query | escape }}".{% else %}Start typing to search.{% endif %}</p>
  {% endfor %}
</main>
</body></html>

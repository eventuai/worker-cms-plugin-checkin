<!doctype html>
<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>{{ guestName | escape }}</title>
<style>body{margin:0;background:#f3f4f6;font-family:system-ui,sans-serif;font-size:16px;color:#111827}.top{display:flex;justify-content:space-between;align-items:center;padding:1rem}.top a{color:#6b7280;text-decoration:none;font-size:.85rem}.card{max-width:28rem;margin:0 auto;padding:0 1rem 2rem}.panel{background:#fff;border-radius:1rem;box-shadow:0 1px 3px #0002;padding:1.25rem;margin-bottom:1rem}h1{margin:0 0 .25rem;font-size:1.4rem}.muted{color:#6b7280;margin:0 0 1rem}h2{font-size:1rem;margin:0 0 .75rem}.row{display:flex;gap:.6rem;align-items:center;justify-content:space-between;padding:.5rem 0;border-bottom:1px solid #f3f4f6}.row:last-child{border-bottom:0}input[type=text]{box-sizing:border-box;padding:.5rem;border:1px solid #d1d5db;border-radius:.4rem;font:inherit;font-size:.9rem;width:9rem}button{border:0;border-radius:.5rem;padding:.6rem 1rem;font:inherit;font-weight:700;cursor:pointer;font-size:.9rem}.btn-primary{background:#4f46e5;color:#fff}.btn-secondary{background:#f3f4f6;color:#374151}.btn-block{width:100%;padding:.9rem;font-size:1.05rem}.badge{display:inline-block;padding:.15rem .6rem;border-radius:9999px;font-size:.75rem;font-weight:700;background:#dcfce7;color:#166534}form.inline{display:inline;margin:0}</style></head>
<body>
<div class="top"><a href="{{ backHref | escape }}">&larr; Scan</a><a href="{{ searchHref | escape }}">Search</a></div>
<main class="card">
  <div class="panel">
    <h1>{{ guestName | escape }}</h1>
    <p class="muted">{{ organization | escape }}{% if email %} &middot; {{ email | escape }}{% endif %}</p>
    {% if mainCheckedIn %}
      <span class="badge">Checked in</span>
      <form class="inline" method="post" action="/kiosk/{{ listId }}/guests/{{ guestId }}/undo-main" style="float:right"><button class="btn-secondary" type="submit">Undo</button></form>
    {% else %}
      <form method="post" action="/kiosk/{{ listId }}/guests/{{ guestId }}/checkin-main"><button class="btn-primary btn-block" type="submit">Check In</button></form>
    {% endif %}
  </div>

  {% if hasPlusGuests %}
  <div class="panel">
    <h2>Plus guests</h2>
    {% for plus in plusGuests %}
      <div class="row">
        <span>{{ plus.label | escape }}</span>
        {% if plus.checkedIn %}
          <form class="inline" method="post" action="/kiosk/{{ listId }}/guests/{{ guestId }}/undo-plus"><input type="hidden" name="index" value="{{ plus.index }}"><button class="btn-secondary" type="submit">Undo</button></form>
        {% else %}
          <form class="inline" method="post" action="/kiosk/{{ listId }}/guests/{{ guestId }}/checkin-plus" style="display:flex;gap:.4rem">
            <input type="hidden" name="index" value="{{ plus.index }}">
            <input type="text" name="name" placeholder="Name (optional)">
            <button class="btn-primary" type="submit">Check in</button>
          </form>
        {% endif %}
      </div>
    {% endfor %}
  </div>
  {% endif %}

  {% if hasSessions %}
  <div class="panel">
    <h2>Sessions</h2>
    {% for session in sessions %}
      <div class="row">
        <span>{{ session.name | escape }}</span>
        {% if session.checkedIn %}
          <form class="inline" method="post" action="/kiosk/{{ listId }}/guests/{{ guestId }}/undo-session"><input type="hidden" name="session_id" value="{{ session.id }}"><button class="btn-secondary" type="submit">Undo</button></form>
        {% else %}
          <form class="inline" method="post" action="/kiosk/{{ listId }}/guests/{{ guestId }}/checkin-session"><input type="hidden" name="session_id" value="{{ session.id }}"><button class="btn-primary" type="submit">Check in</button></form>
        {% endif %}
      </div>
    {% endfor %}
  </div>
  {% endif %}

  <div class="panel">
    <h2>RFID tag</h2>
    <p class="muted">{% if rfid != blank %}Currently bound to: {{ rfid | escape }}{% else %}No tag bound yet.{% endif %}</p>
    <form method="post" action="/kiosk/{{ listId }}/guests/{{ guestId }}/save-rfid" style="display:flex;gap:.5rem">
      <input type="text" name="tag" placeholder="Scan or type tag" autocomplete="off" style="flex:1">
      <button class="btn-secondary" type="submit">Save</button>
    </form>
  </div>

  <div class="panel">
    <h2>Badge</h2>
    <img src="{{ badgeHref | escape }}" alt="Badge preview" style="width:100%;border:1px solid #e5e7eb;border-radius:.5rem;margin-bottom:.75rem">
    <button class="btn-primary btn-block" id="printBadgeBtn" type="button" data-badge-href="{{ badgeHref | escape }}" data-width-mm="60" data-height-mm="30">Print badge</button>
    <p class="muted" style="margin-top:.5rem;font-size:.8rem">Uses the printer configured in <a href="{{ settingsHref | escape }}">Settings</a>.</p>
  </div>
</main>
<textarea id="bitmapOutput" style="display:none" aria-hidden="true"></textarea>
<script src="/assets/js/encoder.js"></script>
<script src="/assets/js/printer.js"></script>
<script src="/assets/js/kiosk.js"></script>
</body></html>

<!doctype html>
<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>{{ guestName | escape }}</title>
<style>
*{box-sizing:border-box}
body{margin:0;background:#f3f4f6;font-family:system-ui,sans-serif;font-size:16px;color:#111827}
.top{display:flex;align-items:center;justify-content:space-between;padding:.75rem 1rem;background:#fff;border-bottom:1px solid #e5e7eb}
.top a{color:#6b7280;text-decoration:none;font-size:.85rem}
.card{max-width:28rem;margin:0 auto;padding:.75rem 1rem 5rem}
.panel{background:#fff;border-radius:1rem;box-shadow:0 1px 3px #0001;padding:1.25rem;margin-bottom:.75rem}
h1{margin:0 0 .25rem;font-size:1.4rem}
.muted{color:#6b7280;margin:0 0 1rem;font-size:.9rem}
h2{font-size:1rem;margin:0 0 .75rem;font-weight:700}
.row{display:flex;gap:.6rem;align-items:center;justify-content:space-between;padding:.5rem 0;border-bottom:1px solid #f3f4f6}
.row:last-child{border-bottom:0}
input[type=text]{padding:.5rem;border:1px solid #d1d5db;border-radius:.4rem;font:inherit;font-size:.9rem;width:9rem}
button{border:0;border-radius:.5rem;padding:.6rem 1rem;font:inherit;font-weight:700;cursor:pointer;font-size:.9rem}
.btn-primary{background:#4f46e5;color:#fff}
.btn-secondary{background:#f3f4f6;color:#374151}
.btn-block{width:100%;padding:.9rem;font-size:1.05rem}
.badge{display:inline-block;padding:.15rem .6rem;border-radius:9999px;font-size:.75rem;font-weight:700;background:#dcfce7;color:#166534}
form.inline{display:inline;margin:0}
/* Bottom navigation */
.bnav{position:fixed;bottom:0;left:0;right:0;background:#fff;border-top:1px solid #e5e7eb;display:flex;z-index:10}
.bnav a{flex:1;display:flex;flex-direction:column;align-items:center;padding:.55rem .5rem .5rem;text-decoration:none;color:#9ca3af;font-size:.65rem;font-weight:600;gap:.2rem;transition:color .15s}
.bnav a svg{width:1.35rem;height:1.35rem}
</style></head>
<body>
<div class="top">
  <a href="{{ backHref | escape }}">&larr; Scan</a>
  <a href="{{ searchHref | escape }}">Search</a>
</div>
<main class="card">
  <div class="panel">
    <h1>{{ guestName | escape }}</h1>
    <p class="muted">{{ organization | escape }}{% if email %} &middot; {{ email | escape }}{% endif %}</p>
    {% if mainCheckedIn %}
      <span class="badge">Checked in</span>
      {% unless mainAtCap %}
        <form class="inline" method="post" action="/kiosk/{{ eventId }}/guests/{{ guestId }}/checkin-main" style="float:right"><button class="btn-secondary" type="submit">Check in again</button></form>
      {% endunless %}
      <form class="inline" method="post" action="/kiosk/{{ eventId }}/guests/{{ guestId }}/undo-main" style="float:right;margin-right:.4rem"><button class="btn-secondary" type="submit">Undo</button></form>
    {% else %}
      <form method="post" action="/kiosk/{{ eventId }}/guests/{{ guestId }}/checkin-main"><button class="btn-primary btn-block" type="submit">Check In</button></form>
    {% endif %}
  </div>

  {% if hasPlusGuests %}
  <div class="panel">
    <h2>Plus guests</h2>
    {% for plus in plusGuests %}
      <div class="row">
        <span>{{ plus.label | escape }}</span>
        {% if plus.checkedIn %}
          <form class="inline" method="post" action="/kiosk/{{ eventId }}/guests/{{ guestId }}/undo-plus"><input type="hidden" name="index" value="{{ plus.index }}"><button class="btn-secondary" type="submit">Undo</button></form>
        {% else %}
          <form class="inline" method="post" action="/kiosk/{{ eventId }}/guests/{{ guestId }}/checkin-plus" style="display:flex;gap:.4rem">
            <input type="hidden" name="index" value="{{ plus.index }}">
            <input type="text" name="name" placeholder="Name (optional)">
            <button class="btn-primary" type="submit">Check in</button>
          </form>
        {% endif %}
      </div>
    {% endfor %}
  </div>
  {% endif %}

  {% if hasSessions %}
  <div class="panel">
    <h2>Sessions</h2>
    {% for session in sessions %}
      <div class="row">
        <span>{{ session.name | escape }}</span>
        {% if session.checkedIn %}
          <form class="inline" method="post" action="/kiosk/{{ eventId }}/guests/{{ guestId }}/undo-session"><input type="hidden" name="session_id" value="{{ session.id }}"><button class="btn-secondary" type="submit">Undo</button></form>
        {% else %}
          <form class="inline" method="post" action="/kiosk/{{ eventId }}/guests/{{ guestId }}/checkin-session"><input type="hidden" name="session_id" value="{{ session.id }}"><button class="btn-primary" type="submit">Check in</button></form>
        {% endif %}
      </div>
    {% endfor %}
  </div>
  {% endif %}

  <div class="panel">
    <h2>RFID tag</h2>
    <p class="muted">{% if rfid != blank %}Bound to: {{ rfid | escape }}{% else %}No tag bound yet.{% endif %}</p>
    <form method="post" action="/kiosk/{{ eventId }}/guests/{{ guestId }}/save-rfid" style="display:flex;gap:.5rem">
      <input type="text" name="tag" placeholder="Scan or type tag" autocomplete="off" style="flex:1">
      <button class="btn-secondary" type="submit">Save</button>
    </form>
  </div>

  <div class="panel">
    <h2>Badge</h2>
    <img src="{{ badgeHref | escape }}" alt="Badge preview" style="width:100%;border:1px solid #e5e7eb;border-radius:.5rem;margin-bottom:.75rem">
    <button class="btn-primary btn-block" id="printBadgeBtn" type="button" data-badge-href="{{ badgeHref | escape }}" data-width-mm="60" data-height-mm="30">Print badge</button>
    <p class="muted" style="margin-top:.5rem;font-size:.8rem">Uses the printer configured in <a href="{{ settingsHref | escape }}" style="color:#4f46e5">Settings</a>.</p>
  </div>
</main>

<nav class="bnav">
  <a href="{{ backHref | escape }}">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"/><circle cx="12" cy="13" r="4"/></svg>
    Scan
  </a>
  <a href="{{ searchHref | escape }}">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    Search
  </a>
  <a href="{{ settingsHref | escape }}">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="21" x2="4" y2="14"/><line x1="4" y1="10" x2="4" y2="3"/><line x1="12" y1="21" x2="12" y2="12"/><line x1="12" y1="8" x2="12" y2="3"/><line x1="20" y1="21" x2="20" y2="16"/><line x1="20" y1="12" x2="20" y2="3"/><line x1="1" y1="14" x2="7" y2="14"/><line x1="9" y1="8" x2="15" y2="8"/><line x1="17" y1="16" x2="23" y2="16"/></svg>
    Settings
  </a>
</nav>

<textarea id="bitmapOutput" style="display:none" aria-hidden="true"></textarea>
<script src="/assets/js/encoder.js"></script>
<script src="/assets/js/printer.js"></script>
<script src="/assets/js/kiosk.js"></script>
</body></html>

<!doctype html>
<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Scan — {{ eventName | escape }}</title>
<style>
*{box-sizing:border-box}
body{margin:0;background:#111827;font-family:system-ui,sans-serif;font-size:16px;color:#fff}
.top{display:flex;align-items:center;padding:.75rem 1rem;border-bottom:1px solid #1f2937}
.top span{font-weight:600;font-size:.95rem;color:#e5e7eb}
.card{max-width:26rem;margin:0 auto;padding:.75rem 1rem 5rem}
video{width:100%;border-radius:1rem;background:#000;aspect-ratio:1/1;object-fit:cover}
.status{text-align:center;margin:.6rem 0;color:#9ca3af;font-size:.85rem}
.error{background:#fee2e2;color:#b91c1c;padding:.6rem 1rem;border-radius:.5rem;margin-bottom:.75rem;font-size:.9rem}
label{display:block;margin:.9rem 0 .35rem;font-weight:600;color:#d1d5db;font-size:.85rem}
input[type=text],input[type=email],input[type=number]{width:100%;padding:.75rem;border:1px solid #374151;border-radius:.5rem;font:inherit;font-size:1rem;background:#1f2937;color:#fff}
input::placeholder{color:#6b7280}
button{border:0;border-radius:.5rem;padding:.75rem 1.2rem;font:inherit;font-weight:700;cursor:pointer;width:100%;margin-top:.65rem}
.btn-primary{background:#4f46e5;color:#fff}
.btn-secondary{background:#1f2937;color:#d1d5db;border:1px solid #374151}
.divider{display:flex;align-items:center;gap:.75rem;margin:1.1rem 0;color:#6b7280;font-size:.75rem;font-weight:600;text-transform:uppercase;letter-spacing:.05em}
.divider::before,.divider::after{content:'';flex:1;border-top:1px solid #374151}
.walk-in-link{display:block;text-align:center;color:#a5b4fc;font-size:.85rem;text-decoration:none;margin-top:.9rem;padding:.5rem}
.adhoc-section{margin-top:1.25rem;border-top:1px solid #374151;padding-top:1.25rem}
/* Bottom navigation */
.bnav{position:fixed;bottom:0;left:0;right:0;background:#1f2937;border-top:1px solid #374151;display:flex;z-index:10}
.bnav a{flex:1;display:flex;flex-direction:column;align-items:center;padding:.55rem .5rem .5rem;text-decoration:none;color:#6b7280;font-size:.65rem;font-weight:600;gap:.2rem;transition:color .15s}
.bnav a svg{width:1.35rem;height:1.35rem}
.bnav a.on{color:#818cf8}
</style></head>
<body>
<div class="top"><span>{{ eventName | escape }}</span></div>
<main class="card">
  {% if error != blank %}<p class="error">{{ error | escape }}</p>{% endif %}
  <video id="scanVideo" playsinline autoplay muted></video>
  <p class="status" id="scanStatus">Starting camera…</p>

  <form id="scanCodeForm" method="post">
    <label for="scanCodeInput">Enter code manually</label>
    <input type="text" name="code" id="scanCodeInput" autocomplete="off" placeholder="QR / barcode / RFID value">
    <button class="btn-primary" type="submit">Find guest</button>
  </form>

  <div class="divider">or search by name</div>

  <form method="get" action="{{ searchHref | escape }}">
    <input type="text" name="q" autocomplete="off" placeholder="Name, email or company…">
    <button class="btn-secondary" type="submit">Search</button>
  </form>

  <a href="#" class="walk-in-link" id="showAdhocForm">+ Walk-in guest</a>
  <form id="adhocForm" method="post" action="{{ adhocHref | escape }}" class="adhoc-section" style="display:none">
    <label for="adhocName">Name</label>
    <input type="text" name="name" id="adhocName" required>
    <label for="adhocOrg">Organization</label>
    <input type="text" name="organization" id="adhocOrg">
    <label for="adhocEmail">Email</label>
    <input type="email" name="email" id="adhocEmail">
    <label for="adhocPlus">Plus guests</label>
    <input type="number" min="0" name="plus_guests" id="adhocPlus" value="0">
    <input type="hidden" name="checkin" value="1">
    <button class="btn-primary" type="submit">Add &amp; check in</button>
  </form>
</main>

<nav class="bnav">
  <a href="/kiosk/{{ eventId }}/scan" class="on">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"/><circle cx="12" cy="13" r="4"/></svg>
    Scan
  </a>
  <a href="{{ searchHref | escape }}">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    Search
  </a>
  <a href="{{ settingsHref | escape }}">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="21" x2="4" y2="14"/><line x1="4" y1="10" x2="4" y2="3"/><line x1="12" y1="21" x2="12" y2="12"/><line x1="12" y1="8" x2="12" y2="3"/><line x1="20" y1="21" x2="20" y2="16"/><line x1="20" y1="12" x2="20" y2="3"/><line x1="1" y1="14" x2="7" y2="14"/><line x1="9" y1="8" x2="15" y2="8"/><line x1="17" y1="16" x2="23" y2="16"/></svg>
    Settings
  </a>
</nav>

<script src="/assets/js/zxing-wasm.js"></script>
<script src="/assets/js/kiosk.js"></script>
</body></html>

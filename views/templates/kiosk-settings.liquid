<!doctype html>
<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Printer settings</title>
<style>body{margin:0;background:#f3f4f6;font-family:system-ui,sans-serif;font-size:16px;color:#111827}.top{display:flex;justify-content:space-between;align-items:center;padding:1rem}.top a{color:#6b7280;text-decoration:none;font-size:.85rem}.card{max-width:28rem;margin:0 auto;padding:0 1rem 2rem}.panel{background:#fff;border-radius:1rem;box-shadow:0 1px 3px #0002;padding:1.25rem;margin-bottom:1rem}h2{font-size:1rem;margin:0 0 .75rem}label{display:flex;align-items:center;gap:.5rem;margin:.5rem 0;font-weight:600;font-size:.9rem}input[type=text]{box-sizing:border-box;width:100%;padding:.6rem;border:1px solid #d1d5db;border-radius:.4rem;font:inherit;font-size:.9rem;margin-top:.4rem}select{box-sizing:border-box;width:100%;padding:.6rem;border:1px solid #d1d5db;border-radius:.4rem;font:inherit;font-size:.9rem}button{border:0;border-radius:.5rem;padding:.6rem 1rem;font:inherit;font-weight:700;cursor:pointer;font-size:.9rem;margin-top:.5rem}.btn-primary{background:#4f46e5;color:#fff}.btn-secondary{background:#f3f4f6;color:#374151}.hidden{display:none}</style></head>
<body>
<div class="top"><a href="{{ backHref | escape }}">&larr; Scan</a><span>Printer settings</span></div>
<main class="card">
  <div class="panel">
    <h2>Printer mode <span id="printerStatus"></span></h2>
    <label><input type="checkbox" id="usbPrinterToggle"> USB printer (WebUSB, Chrome/Edge only)</label>
    <label><input type="checkbox" id="serverPrinterToggle"> Printer server (local relay, works on any browser)</label>

    <div id="serverUrlSection" class="hidden">
      <label for="printerServerUrl">Printer server URL</label>
      <input type="text" id="printerServerUrl" placeholder="https://labelmaker.local/print">
      <button class="btn-secondary" id="testServerBtn" type="button">Test connection</button>

      <label for="printerListUrl" style="margin-top:1rem">Printer list URL</label>
      <input type="text" id="printerListUrl" placeholder="https://labelmaker.local/printers/list">
      <button class="btn-secondary" id="listPrintersBtn" type="button">List printers</button>
      <button class="btn-secondary" id="refresh_printers" type="button">Refresh printers</button>

      <div id="printerSelectContainer" class="hidden" style="margin-top:.75rem">
        <label for="printerSelect">Selected printer</label>
        <select id="printerSelect"></select>
      </div>
    </div>

    <button class="btn-primary" id="manualRequest" type="button" style="width:100%;margin-top:1rem">Pair USB printer</button>
    <button class="btn-secondary" id="rawPrint" type="button" style="width:100%">Send test print</button>
  </div>
</main>
<textarea id="bitmapOutput" style="display:none" aria-hidden="true">1B 69 61 01</textarea>
<script src="/assets/js/printer.js"></script>
</body></html>

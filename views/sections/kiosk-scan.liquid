<div class="max-w-md">
  <div class="mb-4">
    <a class="inline-block text-xs font-medium text-gray-500 hover:text-indigo-700" href="/admin/plugins/checkin/events/{{ eventId }}">&larr; {{ eventName | escape }}</a>
  </div>

  {% if error != blank %}<p class="mb-4 bg-red-50 text-red-600 rounded-lg px-4 py-2 text-sm">{{ error | escape }}</p>{% endif %}

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 mb-4">
    <video id="scanVideo" class="w-full rounded-lg" style="aspect-ratio:1/1;object-fit:cover;background:#111827" playsinline autoplay muted></video>
    <p id="scanStatus" class="text-center text-sm text-gray-500 mt-2">Starting camera&hellip;</p>

    <form id="scanCodeForm" method="post" action="{{ scanAction | escape }}" class="mt-4">
      <label for="scanCodeInput" class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Enter code manually</label>
      <input type="text" name="code" id="scanCodeInput" autocomplete="off" class="w-full block px-3 py-2 border border-gray-300 rounded-lg text-sm" placeholder="QR / barcode / RFID value">
      <button type="submit" class="w-full mt-2 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-lg px-4 py-2 text-sm cursor-pointer">Find guest</button>
    </form>
  </div>

  <form method="get" action="{{ searchHref | escape }}" class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 mb-4">
    <label for="scanSearchInput" class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Or search by name</label>
    <input type="text" name="q" id="scanSearchInput" autocomplete="off" class="w-full block px-3 py-2 border border-gray-300 rounded-lg text-sm" placeholder="Name, email or company&hellip;">
    <button type="submit" class="w-full mt-2 bg-gray-100 hover:bg-gray-200 text-gray-700 font-semibold rounded-lg px-4 py-2 text-sm cursor-pointer">Search</button>
  </form>

  {% if canCheckIn %}
  <a href="#" id="showAdhocForm" class="block text-center text-sm text-indigo-600 hover:text-indigo-800 font-medium py-2">+ Walk-in guest</a>
  <form id="adhocForm" method="post" action="{{ adhocHref | escape }}" class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 hidden">
    <label for="adhocName" class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Name</label>
    <input type="text" name="name" id="adhocName" required class="w-full block px-3 py-2 border border-gray-300 rounded-lg text-sm mb-2">
    <label for="adhocOrg" class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Organization</label>
    <input type="text" name="organization" id="adhocOrg" class="w-full block px-3 py-2 border border-gray-300 rounded-lg text-sm mb-2">
    <label for="adhocEmail" class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Email</label>
    <input type="email" name="email" id="adhocEmail" class="w-full block px-3 py-2 border border-gray-300 rounded-lg text-sm mb-2">
    <label for="adhocPlus" class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Plus guests</label>
    <input type="number" min="0" name="plus_guests" id="adhocPlus" value="0" class="w-full block px-3 py-2 border border-gray-300 rounded-lg text-sm mb-2">
    <input type="hidden" name="checkin" value="1">
    <button type="submit" class="w-full mt-2 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-lg px-4 py-2 text-sm cursor-pointer">Add &amp; check in</button>
  </form>
  {% endif %}
</div>

<link rel="preload" href="/admin/plugins/checkin/assets/wasm/zxing_reader.wasm" as="fetch" type="application/wasm" crossorigin="anonymous">
<script src="/admin/plugins/checkin/assets/js/zxing-wasm.js"></script>
<script src="/admin/plugins/checkin/assets/js/kiosk.js"></script>

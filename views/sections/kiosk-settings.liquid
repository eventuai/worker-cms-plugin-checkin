<div class="max-w-md">
  <div class="mb-4 flex items-center justify-between gap-4">
    <a class="text-sm text-gray-500 hover:text-indigo-700" href="{{ backHref | escape }}">&larr; Scan</a>
    <a class="text-sm text-indigo-600 hover:text-indigo-800 font-medium" href="{{ searchHref | escape }}">Search</a>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5 mb-4">
    <h1 class="text-2xl font-bold text-gray-900 mb-2">Printer mode <span id="printerStatus" class="text-sm text-gray-400"></span></h1>
    <label class="flex items-center gap-2 text-sm text-gray-700 py-1"><input type="checkbox" id="usbPrinterToggle"> USB printer (WebUSB, Chrome/Edge only)</label>
    <label class="flex items-center gap-2 text-sm text-gray-700 py-1"><input type="checkbox" id="serverPrinterToggle"> Printer server (local relay, works on any browser)</label>

    <div id="serverUrlSection" class="hidden mt-2">
      <label for="printerServerUrl" class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1 mt-2">Printer server URL</label>
      <input type="text" id="printerServerUrl" placeholder="https://labelmaker.local/print" class="w-full block px-3 py-2 border border-gray-300 rounded-lg text-sm">
      <button type="button" id="testServerBtn" class="mt-2 bg-gray-100 hover:bg-gray-200 text-gray-700 font-semibold rounded-lg px-4 py-2 text-sm cursor-pointer">Test connection</button>

      <label for="printerListUrl" class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1 mt-4">Printer list URL</label>
      <input type="text" id="printerListUrl" placeholder="https://labelmaker.local/printers/list" class="w-full block px-3 py-2 border border-gray-300 rounded-lg text-sm">
      <div class="flex gap-2 mt-2">
        <button type="button" id="listPrintersBtn" class="bg-gray-100 hover:bg-gray-200 text-gray-700 font-semibold rounded-lg px-4 py-2 text-sm cursor-pointer">List printers</button>
        <button type="button" id="refresh_printers" class="bg-gray-100 hover:bg-gray-200 text-gray-700 font-semibold rounded-lg px-4 py-2 text-sm cursor-pointer">Refresh printers</button>
      </div>

      <div id="printerSelectContainer" class="hidden mt-2">
        <label for="printerSelect" class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Selected printer</label>
        <select id="printerSelect" class="w-full block px-3 py-2 border border-gray-300 rounded-lg text-sm bg-white"></select>
      </div>
    </div>

    <button type="button" id="manualRequest" class="w-full mt-4 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-lg px-4 py-2 cursor-pointer">Pair USB printer</button>
    <button type="button" id="rawPrint" class="w-full mt-2 bg-gray-100 hover:bg-gray-200 text-gray-700 font-semibold rounded-lg px-4 py-2 cursor-pointer">Send test print</button>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5">
    <h2 class="text-base font-bold text-gray-900 mb-1">Event</h2>
    <p class="text-sm text-gray-500">{{ eventName | escape }}</p>
  </div>
</div>

<textarea id="bitmapOutput" class="hidden" aria-hidden="true">1B 69 61 01</textarea>
<script src="/admin/plugins/checkin/assets/js/printer.js"></script>

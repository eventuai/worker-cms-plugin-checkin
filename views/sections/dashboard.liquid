<div class="flex items-center justify-between gap-4 mb-4">
  <div><h1 class="text-2xl font-bold text-gray-900">Check-in</h1><p class="mt-1 text-sm text-gray-500">Events with check-in-relevant configuration.</p></div>
</div>
<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto">
  <table class="w-full min-w-[560px] text-left relative">
    <thead class="bg-gray-50 border-b border-gray-200"><tr><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Event</th><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Kiosk title</th><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Login required</th><th class="px-6 py-3"></th></tr></thead>
    <tbody class="divide-y divide-gray-100">
      {% for event in events %}
        <tr>
          <td class="px-6 py-3 text-sm text-gray-700"><a class="text-indigo-600 font-medium hover:text-indigo-800" href="{{ event.href | escape }}">{{ event.name | escape }}</a></td>
          <td class="px-6 py-3 text-sm text-gray-500">{{ event.kioskTitle | escape }}</td>
          <td class="px-6 py-3 text-sm text-gray-700">{% if event.requiresLogin %}<span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-700">CMS login</span>{% else %}<span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-700">Kiosk passcode</span>{% endif %}</td>
          <td class="px-6 py-3 text-right text-sm"><a class="text-indigo-600 font-medium hover:text-indigo-800" href="{{ event.href | escape }}">→</a></td>
        </tr>
      {% else %}
        <tr><td colspan="4" class="px-6 py-10 text-center text-sm text-gray-400">No events yet.</td></tr>
      {% endfor %}
    </tbody>
  </table>
</div>

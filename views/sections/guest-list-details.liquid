<div class="flex items-center justify-between gap-4 mb-4">
  <div>
    <a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="{{ backHref | escape }}">← {{ eventName | escape }}</a>
    <h1 class="text-2xl font-bold text-gray-900">{{ listName | escape }}</h1>
    <p class="mt-1 text-sm text-gray-500">{{ guests.size }} guest{% unless guests.size == 1 %}s{% endunless %}</p>
  </div>
</div>

<div class="mb-4 flex items-center justify-between gap-4 rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
  <form class="flex flex-wrap items-center gap-3" method="get" action="{{ detailHref | escape }}" data-table-filter-form data-table-filter-target="[data-table-filter='guests']" data-table-filter-count-target="[data-table-filter-count='guests']" data-table-filter-count-label-target="[data-table-filter-count-label='guests']">
    <input class="block max-w-[22rem] rounded-lg border border-gray-300 px-3 py-2 text-sm" name="q" placeholder="Search name, email or organisation" aria-label="Search guests">
    <select class="block rounded-lg border border-gray-300 px-3 py-2 text-sm" name="status" aria-label="Filter by status">
      <option value="">All statuses</option>
      {% for status in statuses %}<option value="{{ status | escape }}">{{ status | escape }}</option>{% endfor %}
    </select>
    <select class="block rounded-lg border border-gray-300 px-3 py-2 text-sm" name="color" aria-label="Filter by color tag">
      <option value="">All color tags</option>
      <option value="none">No color tag</option>
      {% for color in colorOptions %}<option value="{{ color.value | escape }}">{{ color.label | escape }}</option>{% endfor %}
    </select>
    <a class="text-sm font-semibold text-gray-500 hover:text-indigo-700" href="{{ detailHref | escape }}" data-table-filter-clear hidden>Clear</a>
  </form>
  <p class="shrink-0 text-sm text-gray-500"><span data-table-filter-count="guests">{{ guests.size }}</span> <span data-table-filter-count-label="guests" data-singular="guest" data-plural="guests">guest{% unless guests.size == 1 %}s{% endunless %}</span></p>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-200">
  <div class="overflow-x-auto w-full">
    <table class="w-full min-w-[680px] text-left" data-table-filter="guests">
      <thead class="border-b border-gray-200 bg-gray-50">
        <tr><th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">Name / Email</th><th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">Organisation</th><th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">Status</th>{% if hasCustomFields %}<th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500"><form method="get" action="{{ detailHref | escape }}"><select class="max-w-[12rem] cursor-pointer border-0 bg-transparent p-0 text-xs font-semibold uppercase tracking-wider text-gray-500" name="cf" data-autosubmit><option value="">Custom field</option>{% for field in customFields %}<option value="{{ field.key | escape }}"{% if field.selected %} selected{% endif %}>{{ field.label | escape }}</option>{% endfor %}</select></form></th>{% endif %}<th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">Check-in</th><th class="px-6 py-3"></th></tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        {% for guest in guests %}
          <tr class="hover:bg-gray-50" data-table-filter-row data-filter-search="{{ guest.searchText | escape }}" data-filter-status="{{ guest.status | escape }}" data-filter-color="{{ guest.colorTag | escape }}">
            <td class="max-w-[400px] px-6 py-3 text-sm text-gray-700">
              <div class="flex min-w-0 items-center gap-2">
                {% render "color-tag-picker", value: guest.colorTag, label: "Color tag" %}
                <div class="min-w-0">
                  <a class="block truncate font-medium text-indigo-600 hover:text-indigo-800" href="{{ guest.guestHref | escape }}">{{ guest.name | escape }}</a>
                  <div class="truncate text-sm text-gray-500">{{ guest.email | escape }}</div>
                </div>
              </div>
            </td>
            <td class="max-w-[400px] truncate overflow-hidden px-6 py-3 text-sm text-gray-700">{{ guest.organization | escape }}{% if guest.plusGuests > 0 %}<div class="text-xs text-gray-500">+{{ guest.plusGuests }} guest{% unless guest.plusGuests == 1 %}s{% endunless %}</div>{% endif %}</td>
            <td class="px-6 py-3 text-sm text-gray-700"><span class="inline-block rounded-full bg-gray-100 px-2 py-0.5 text-xs font-semibold text-gray-700">{{ guest.status | escape }}</span></td>
            {% if hasCustomFields %}<td class="px-6 py-3 text-sm text-gray-700">{% if selectedCustomFieldKey != blank %}{% if guest.customFieldValue != blank %}{{ guest.customFieldValue | escape }}{% else %}<span class="italic text-gray-400">—</span>{% endif %}{% else %}<span class="italic text-gray-400">—</span>{% endif %}</td>{% endif %}
            <td class="px-6 py-3 text-sm text-gray-700">{% if guest.checkedIn %}<span class="inline-block rounded-full bg-gray-100 px-2 py-0.5 text-xs font-semibold text-gray-700">Checked in</span>{% else %}<span class="text-xs text-gray-400">Not checked in</span>{% endif %}</td>
            <td class="px-6 py-3 text-right"><a class="text-sm font-medium text-indigo-600 hover:text-indigo-800" href="{{ guest.guestHref | escape }}">Open →</a></td>
          </tr>
        {% else %}
          <tr><td colspan="{% if hasCustomFields %}6{% else %}5{% endif %}" class="px-6 py-10 text-center text-sm text-gray-400">No guests in this list yet.</td></tr>
        {% endfor %}
        {% if hasGuests %}<tr hidden data-table-filter-empty><td colspan="{% if hasCustomFields %}6{% else %}5{% endif %}" class="px-6 py-10 text-center text-sm text-gray-400">No guests match this filter.</td></tr>{% endif %}
      </tbody>
    </table>
  </div>
</div>

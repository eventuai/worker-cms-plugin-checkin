<div class="flex items-center justify-between gap-4 mb-4">
  <div>
    <a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="{{ dashboardHref | escape }}">← Check-in</a>
    <h1 class="text-2xl font-bold text-gray-900">{{ eventName | escape }}</h1>
    <p class="mt-1 text-sm text-gray-500">{{ kioskTitle | escape }}</p>
  </div>
  <div class="text-right">
    <a class="inline-block text-indigo-600 font-medium hover:text-indigo-800" href="{{ launchKioskHref | escape }}">Launch kiosk →</a>
    <p class="mt-1 text-xs text-gray-400">Opens the door check-in scanner</p>
  </div>
</div>

<!-- Quick navigation -->
<div class="flex gap-2 mb-4">
  <a href="{{ dashboardHref | escape }}" class="inline-flex items-center gap-2 bg-white border border-gray-200 rounded-lg px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">Events</a>
  <a href="{{ scanHref | escape }}" class="inline-flex items-center gap-2 bg-white border border-gray-200 rounded-lg px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">Scan</a>
  <a href="{{ settingsHref | escape }}" class="inline-flex items-center gap-2 bg-white border border-gray-200 rounded-lg px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">Settings</a>
</div>

<!-- Search all guests on this event -->
<form method="get" action="{{ searchHref | escape }}" class="flex gap-2 mb-4 sticky top-4 z-10 bg-gray-50 drop-shadow-lg">
  <input type="text" name="q" autocomplete="off" class="w-full block px-3 py-2 border border-gray-300 rounded-lg text-sm" placeholder="Search all guests by name, email or company…">
  <button type="submit" class="bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-lg px-4 py-2 text-sm cursor-pointer whitespace-nowrap">Search</button>
</form>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto">
  <table class="w-full min-w-[560px] text-left relative">
    <thead class="bg-gray-50 border-b border-gray-200"><tr><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Guest list</th><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Checked in</th><th class="px-6 py-3"></th></tr></thead>
    <tbody class="divide-y divide-gray-100">
      {% for list in lists %}
        <tr>
          <td class="px-6 py-3 text-sm text-gray-700">{{ list.name | escape }}{% unless list.allowCheckin %} <span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-700">disabled</span>{% endunless %}</td>
          <td class="px-6 py-3 text-sm text-gray-700">{{ list.checkedIn }} / {{ list.total }} <span class="text-gray-400">({{ list.checkedInHeadcount }} / {{ list.totalHeadcount }} guests)</span></td>
          <td class="px-6 py-3 text-right text-sm"><a class="text-indigo-600 font-medium hover:text-indigo-800" href="{{ list.searchHref | escape }}">Search guests →</a></td>
        </tr>
      {% else %}
        <tr><td colspan="3" class="px-6 py-10 text-center text-sm text-gray-400">No guest lists on this event yet.</td></tr>
      {% endfor %}
    </tbody>
  </table>
</div>

{% if hasCustomFields %}
<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mt-4">
  <h2 class="text-lg font-bold text-gray-900 mb-3">Search by custom field</h2>
  <form method="get" action="{{ searchHref | escape }}" class="grid grid-cols-1 sm:grid-cols-3 gap-2">
    <select name="field" class="w-full block px-3 py-2 border border-gray-300 rounded-lg text-sm bg-white">
      {% for field in customFields %}
        <option value="{{ field.value | escape }}">{{ field.label | escape }}</option>
      {% endfor %}
    </select>
    <input type="text" name="q" autocomplete="off" class="w-full block px-3 py-2 border border-gray-300 rounded-lg text-sm" placeholder="Value to search…">
    <button type="submit" class="bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-lg px-4 py-2 text-sm cursor-pointer">Search</button>
  </form>
</div>
{% endif %}

<!-- Event summary -->
<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mt-4">
  <h2 class="text-lg font-bold text-gray-900 mb-3">Event summary</h2>
  <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
    <div>
      <div class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-1">All guests</div>
      <div class="text-2xl font-bold text-gray-900">{{ summary.guestCount }}</div>
      <div class="text-xs text-gray-400 mt-1">{{ summary.guestTotal }} incl. plus guests</div>
    </div>
    <div>
      <div class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-1">Checked in</div>
      <div class="text-2xl font-bold text-green-800">{{ summary.checkedInCount }}</div>
      <div class="text-xs text-gray-400 mt-1">{{ summary.checkedInTotal }} incl. plus guests</div>
    </div>
    <div>
      <div class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-1">Rate</div>
      <div class="text-2xl font-bold text-gray-900">{{ summary.checkedInPercent }}%</div>
      <div class="text-xs text-gray-400 mt-1">{{ summary.checkedInCount }} / {{ summary.guestCount }} guests</div>
    </div>
  </div>
</div>

{% if canCheckIn %}
<!-- Check in an unlisted (walk-in) guest -->
<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mt-4 sticky bottom-0 z-10 drop-shadow-lg" data-walkin-panel data-storage-key="checkin:event-dashboard:walkin-collapsed:{{ eventId | escape }}">
  <div class="flex items-start justify-between gap-4">
    <h2 class="text-lg font-bold text-gray-900">Check in unlisted guest</h2>
    <button type="button" class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-gray-300 bg-white px-3 text-sm font-semibold text-gray-700 hover:bg-gray-50" data-walkin-toggle aria-expanded="true" aria-controls="walkinPanelBody" title="Collapse panel" aria-label="Collapse panel">
      <svg data-walkin-toggle-icon class="h-4 w-4 transition-transform" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M6 15l6-6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
      <span data-walkin-toggle-label class="hidden sm:inline">Collapse</span>
    </button>
  </div>
  <div id="walkinPanelBody" data-walkin-panel-body class="mt-3">
    <p class="text-sm text-gray-500 mb-3">Adds a walk-in to the event's adhoc list and checks them in.</p>
    <form method="post" action="{{ walkinHref | escape }}" class="grid grid-cols-1 sm:grid-cols-2 gap-2">
      <input type="text" name="name" required autocomplete="off" class="w-full block px-3 py-2 border border-gray-300 rounded-lg text-sm" placeholder="Full name *">
      <input type="text" name="organization" autocomplete="off" class="w-full block px-3 py-2 border border-gray-300 rounded-lg text-sm" placeholder="Organization">
      <input type="email" name="email" autocomplete="off" class="w-full block px-3 py-2 border border-gray-300 rounded-lg text-sm" placeholder="Email">
      <input type="number" name="plus_guests" min="0" value="0" class="w-full block px-3 py-2 border border-gray-300 rounded-lg text-sm" placeholder="Plus guests">
      <input type="hidden" name="checkin" value="1">
      <button type="submit" class="sm:col-span-2 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-lg px-4 py-2 text-sm cursor-pointer">Add &amp; check in</button>
    </form>
  </div>
</div>
<script src="/admin/plugins/checkin/assets/js/event-dashboard.js"></script>
{% endif %}

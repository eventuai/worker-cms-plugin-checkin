<div class="flex items-center justify-between gap-4 mb-4">
  <div>
    <a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="/admin/plugins/checkin/dashboard">← Check-in</a>
    <h1 class="text-2xl font-bold text-gray-900">{{ eventName | escape }}</h1>
    <p class="mt-1 text-sm text-gray-500">{{ kioskTitle | escape }}</p>
  </div>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto">
  <table class="w-full min-w-[560px] text-left relative">
    <thead class="bg-gray-50 border-b border-gray-200"><tr><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Guest list</th><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Checked in</th><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Kiosk</th><th class="px-6 py-3"></th></tr></thead>
    <tbody class="divide-y divide-gray-100">
      {% for list in lists %}
        <tr>
          <td class="px-6 py-3 text-sm text-gray-700">{{ list.name | escape }}{% unless list.allowCheckin %} <span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-700">disabled</span>{% endunless %}</td>
          <td class="px-6 py-3 text-sm text-gray-700">{{ list.checkedIn }} / {{ list.total }} <span class="text-gray-400">({{ list.checkedInHeadcount }} / {{ list.totalHeadcount }} guests)</span></td>
          <td class="px-6 py-3 text-sm text-gray-500">{% if list.hasPasscode %}<a class="text-indigo-600 font-medium hover:text-indigo-800" href="{{ list.kioskHref | escape }}" target="_blank" rel="noopener">Open kiosk →</a>{% else %}<span class="text-gray-400">No passcode set</span>{% endif %}</td>
          <td class="px-6 py-3 text-right text-sm"><a class="text-indigo-600 font-medium hover:text-indigo-800" href="{{ list.searchHref | escape }}">Search guests →</a></td>
        </tr>
      {% else %}
        <tr><td colspan="4" class="px-6 py-10 text-center text-sm text-gray-400">No guest lists on this event yet.</td></tr>
      {% endfor %}
    </tbody>
  </table>
</div>

{% if sessions.size > 0 %}
<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mt-4">
  <h2 class="text-lg font-bold text-gray-900 mb-3">Check-in sessions</h2>
  <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
    {% for session in sessions %}
      <div class="border border-gray-200 rounded-lg p-3 text-center"><span class="text-sm text-gray-700">{{ session.name | escape }}</span></div>
    {% endfor %}
  </div>
</div>
{% endif %}

<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mt-4">
  <h2 class="text-lg font-bold text-gray-900 mb-3">Recent activity</h2>
  {% if activity.size > 0 %}
    <ul class="divide-y divide-gray-100">
      {% for entry in activity %}
        <li class="py-2 text-sm text-gray-700"><a class="text-indigo-600 font-medium hover:text-indigo-800" href="{{ entry.searchHref | escape }}">{{ entry.guestName | escape }}</a> — {{ entry.message | escape }} <span class="text-gray-400">({{ entry.listName | escape }}, {{ entry.date | escape }})</span></li>
      {% endfor %}
    </ul>
  {% else %}
    <p class="text-sm text-gray-400">No check-ins yet.</p>
  {% endif %}
</div>

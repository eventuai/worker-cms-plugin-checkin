<div class="flex items-center justify-between gap-4 mb-4">
  <div><h1 class="text-2xl font-bold text-gray-900">Search — {{ listName | escape }}</h1></div>
</div>
<form class="mb-4" method="get" action="{{ searchAction | escape }}">
  <input class="w-full block px-3 py-2 border border-gray-300 rounded-lg text-sm" name="q" value="{{ query | escape }}" placeholder="Search name, email or company">
</form>
<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto">
  <table class="w-full min-w-[560px] text-left relative">
    <thead class="bg-gray-50 border-b border-gray-200"><tr><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Guest</th><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Organization</th><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th><th class="px-6 py-3"></th></tr></thead>
    <tbody class="divide-y divide-gray-100">
      {% for guest in guests %}
        <tr>
          <td class="px-6 py-3 text-sm text-gray-700">{{ guest.name | escape }}<br><span class="text-xs text-gray-400">{{ guest.email | escape }}</span></td>
          <td class="px-6 py-3 text-sm text-gray-500">{{ guest.organization | escape }}</td>
          <td class="px-6 py-3 text-sm">{% if guest.checkedIn %}<span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-700">Checked in</span>{% else %}<span class="text-gray-400 text-xs">Not checked in</span>{% endif %}</td>
          <td class="px-6 py-3 text-right text-sm">
            {% unless guest.checkedIn %}<form method="post" action="{{ checkinAction | escape }}/{{ guest.id }}/checkin" class="inline"><input type="hidden" name="return_to" value="{{ returnTo | escape }}"><button class="border-0 bg-transparent p-0 text-xs font-semibold text-indigo-600 cursor-pointer" type="submit">Check in</button></form>{% else %}<form method="post" action="{{ checkinAction | escape }}/{{ guest.id }}/undo" class="inline"><input type="hidden" name="return_to" value="{{ returnTo | escape }}"><button class="border-0 bg-transparent p-0 text-xs font-semibold text-red-600 cursor-pointer" type="submit">Undo</button></form>{% endunless %}
          </td>
        </tr>
      {% else %}
        <tr><td colspan="4" class="px-6 py-10 text-center text-sm text-gray-400">{% if query != blank %}No guests match "{{ query | escape }}".{% else %}Search for a guest by name, email or company.{% endif %}</td></tr>
      {% endfor %}
    </tbody>
  </table>
</div>

<div class="flex items-center justify-between gap-4 mb-4">
  <div><h1 class="text-2xl font-bold text-gray-900">{{ "checkin.common.search" | t }} — {{ listName }}</h1></div>
</div>
<form class="mb-4" method="get" action="{{ searchAction }}">
  <input class="w-full block px-3 py-2 border border-gray-300 rounded-lg text-sm" name="q" value="{{ query }}" placeholder="{{ "checkin.common.search_name_email_company" | t }}">
</form>
<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto">
  <table class="w-full min-w-[560px] text-left relative">
    <thead class="bg-gray-50 border-b border-gray-200"><tr><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ "checkin.common.guest" | t }}</th><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ "checkin.common.organization" | t }}</th><th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ "checkin.common.status" | t }}</th><th class="px-6 py-3"></th></tr></thead>
    <tbody class="divide-y divide-gray-100">
      {% for guest in guests %}
        <tr>
          <td class="px-6 py-3 text-sm text-gray-700">{{ guest.name }}<br><span class="text-xs text-gray-400">{{ guest.email }}</span></td>
          <td class="px-6 py-3 text-sm text-gray-500">{{ guest.organization }}</td>
          <td class="px-6 py-3 text-sm">{% if guest.checkedIn %}<span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-700">{{ "checkin.common.checked_in" | t }}</span>{% else %}<span class="text-gray-400 text-xs">{{ "checkin.common.not_checked_in" | t }}</span>{% endif %}</td>
          <td class="px-6 py-3 text-right text-sm">
            {% unless guest.checkedIn %}<form method="post" action="{{ checkinAction }}/{{ guest.id }}/checkin" class="inline"><input type="hidden" name="return_to" value="{{ returnTo }}"><button class="border-0 bg-transparent p-0 text-xs font-semibold text-indigo-600 cursor-pointer" type="submit">{{ "checkin.common.check_in" | t }}</button></form>{% else %}<form method="post" action="{{ checkinAction }}/{{ guest.id }}/undo" class="inline"><input type="hidden" name="return_to" value="{{ returnTo }}"><button class="border-0 bg-transparent p-0 text-xs font-semibold text-red-600 cursor-pointer" type="submit">{{ "checkin.common.undo" | t }}</button></form>{% endunless %}
          </td>
        </tr>
      {% else %}
        <tr><td colspan="4" class="px-6 py-10 text-center text-sm text-gray-400">{% if query != blank %}{{ "checkin.common.no_guests_match" | t }} "{{ query }}".{% else %}{{ "checkin.views.guest_search.search_help" | t }}{% endif %}</td></tr>
      {% endfor %}
    </tbody>
  </table>
</div>

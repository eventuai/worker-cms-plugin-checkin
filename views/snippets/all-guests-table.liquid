<div class="bg-white rounded-xl shadow-sm border border-gray-200">
  <div class="flex justify-end px-4 py-3" data-privacy-control>
    <button type="button" data-privacy-toggle class="inline-flex h-8 items-center justify-center gap-2 rounded-lg border border-gray-300 bg-white px-3 text-xs font-semibold text-gray-700 hover:bg-gray-50" aria-label="{{ "checkin.common.reveal_private_fields" | t }}" title="{{ "checkin.common.reveal_private_fields" | t }}">
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="/assets/icons.svg#eye-off"></use></svg>
      <span data-privacy-toggle-label>{{ "checkin.common.reveal" | t }}</span>
    </button>
  </div>
  <div class="overflow-x-auto w-full">
    <div data-privacy-control hidden></div>
    <table class="w-full min-w-[780px] text-left" data-table-filter="guests" data-privacy-table>
      <thead class="border-b border-gray-200 bg-gray-50">
        <tr><th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">{{ "checkin.common.name_email" | t }}</th><th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">{{ "checkin.common.guest_list" | t }}</th><th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">{{ "checkin.common.organization" | t }}</th><th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">{{ "checkin.common.status" | t }}</th>{% if hasCustomFields %}<th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500"><form method="get" action="{{ detailHref }}"><select class="max-w-[12rem] cursor-pointer border-0 bg-transparent p-0 text-xs font-semibold uppercase tracking-wider text-gray-500" name="cf" data-autosubmit><option value="">{{ "checkin.common.custom_field" | t }}</option>{% for field in customFields %}<option value="{{ field.key }}"{% if field.selected %} selected{% endif %}>{{ field.label }}</option>{% endfor %}</select></form></th>{% endif %}<th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">{{ "checkin.common.check_in" | t }}</th><th class="px-6 py-3"></th></tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        {% for guest in guests %}
          <tr class="hover:bg-gray-50" data-table-filter-row data-guest-row data-filter-search="{{ guest.searchText }}" data-filter-status="{{ guest.status }}" data-filter-color="{{ guest.colorTag }}">
            <td class="max-w-[400px] px-6 py-3 text-sm text-gray-700">
              <div class="flex min-w-0 items-center gap-2">
                <span data-guest-color>{% render "color-tag-picker", value: guest.colorTag, label: "checkin.common.color_tag" | t %}</span>
                <div class="min-w-0">
                  <a class="block truncate font-medium text-indigo-600 hover:text-indigo-800" href="{{ guest.guestHref }}" data-private-field="name" data-guest-name>{{ guest.name }}</a>
                  <div class="truncate text-sm text-gray-500" data-private-field="email" data-guest-email>{{ guest.email }}</div>
                </div>
              </div>
            </td>
            <td class="whitespace-nowrap px-6 py-3 text-sm text-gray-700" data-guest-list>{{ guest.listName }}</td>
            <td class="max-w-[400px] truncate overflow-hidden px-6 py-3 text-sm text-gray-700"><span data-guest-organization>{{ guest.organization }}</span><div class="text-xs text-gray-500" data-guest-plus{% unless guest.plusGuests > 0 %} hidden{% endunless %}>+<span data-guest-plus-count>{{ guest.plusGuests }}</span> <span data-guest-plus-label>{% if guest.plusGuests == 1 %}{{ "checkin.common.guest" | t }}{% else %}{{ "checkin.common.guests" | t }}{% endif %}</span></div></td>
            <td class="px-6 py-3 text-sm text-gray-700"><span class="inline-block rounded-full bg-gray-100 px-2 py-0.5 text-xs font-semibold text-gray-700" data-guest-status>{{ guest.status }}</span></td>
            {% if hasCustomFields %}<td class="px-6 py-3 text-sm text-gray-700"><span data-guest-custom-field{% if guest.customFieldValue == blank %} class="italic text-gray-400"{% endif %}>{% if selectedCustomFieldKey != blank and guest.customFieldValue != blank %}{{ guest.customFieldValue }}{% else %}—{% endif %}</span></td>{% endif %}
            <td class="px-6 py-3 text-sm text-gray-700" data-guest-checkin>{% if guest.checkedIn %}<span class="inline-block rounded-full bg-gray-100 px-2 py-0.5 text-xs font-semibold text-gray-700">{{ "checkin.common.checked_in" | t }}</span>{% else %}<span class="text-xs text-gray-400">{{ "checkin.common.not_checked_in" | t }}</span>{% endif %}</td>
            <td class="px-6 py-3 text-right"><a class="text-sm font-medium text-indigo-600 hover:text-indigo-800" href="{{ guest.guestHref }}" data-guest-open>{{ "checkin.common.open" | t }} →</a></td>
          </tr>
        {% else %}
          <tr data-table-filter-empty><td colspan="{% if hasCustomFields %}7{% else %}6{% endif %}" class="px-6 py-10 text-center text-sm text-gray-400">{{ "checkin.views.all_guests.no_guests_on_event" | t }}</td></tr>
        {% endfor %}
        {% if hasGuests %}<tr hidden data-table-filter-empty><td colspan="{% if hasCustomFields %}7{% else %}6{% endif %}" class="px-6 py-10 text-center text-sm text-gray-400">{{ "checkin.common.no_guests_match_filter" | t }}</td></tr>{% endif %}
      </tbody>
    </table>
  </div>
</div>
